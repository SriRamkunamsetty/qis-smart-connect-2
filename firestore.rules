rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated and is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Notices, Events, Gallery, Placements:
    // Any authenticated user can read.
    // Only Admin can write.
    match /circulars/{document} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /events/{document} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /gallery/{document} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /placements/{document} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /stats/{document} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // Users Collection rules
    match /users/{userId} {
      // Any authenticated user can read their own profile, Admins can read all.
      // (Faculty might need to read all users too, but adhering to prompt: users can read own profile).
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      
      // Allow users to create their own record on signup
      allow create: if isAuth() && request.auth.uid == userId;
      
      // Allow user to write/update their own profile EXCEPT role. Admin can update anything.
      allow update: if isAuth() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || 
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // Fallback: Default lock
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
